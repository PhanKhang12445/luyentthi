# Local Docker/PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=exam_preparation
DB_SSL=false

# Render + Supabase
# Paste Supabase connection string here on Render.
# Example: postgresql://postgres.xxx:password@aws-0-region.pooler.supabase.com:6543/postgres
DATABASE_URL=

# Server
PORT=5000
NODE_ENV=development

# Gemini AI OCR, optional
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# File upload
UPLOAD_DIR=uploads
MAX_FILE_SIZE=10485760
